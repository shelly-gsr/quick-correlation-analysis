# *************************************************
# 1.0 Imports ----
# *************************************************
library(tidyverse)
library(tidyquant)
library(stringr)
library(forcats)
# ************************************************* ----
# 2.0 Load ----
# *************************************************
# clear all variables in work space
rm(list = ls())
# input - new segmented data
raw_data <- read.csv("Desktop/transformed_data.csv")
source("Desktop/plot_cor.R")
# ************************************************* ----
# 4.0 Correlation Funnels ----
# *************************************************
#create recipe for the discretize object
discretize_obj <- recipe(~ ., data = raw_data) %>%
step_zv(all_predictors()) %>%
step_discretize(all_numeric(), options = list(min_unique = 1)) %>%
step_dummy(all_nominal(), one_hot = TRUE) %>%
prep()
library(recipes)
# ************************************************* ----
# 4.0 Correlation Funnels ----
# *************************************************
#create recipe for the discretize object
discretize_obj <- recipe(~ ., data = raw_data) %>%
step_zv(all_predictors()) %>%
step_discretize(all_numeric(), options = list(min_unique = 1)) %>%
step_dummy(all_nominal(), one_hot = TRUE) %>%
prep()
# ************************************************* ----
# 4.0 Data Preparation ----
# *************************************************
transformed_data <- raw_data %>%
select('Start_Lng', 'Distance(mi)', 'Start_Lat', 'Pressure(in)',
'Humidity(%)', 'Wind_Chill(F)', 'Temperature_C',
'Weather_Condition', 'Airport_Code', 'Timezone')
# ************************************************* ----
# 4.0 Data Preparation ----
# *************************************************
transformed_data <- raw_data %>%
select('Start_Lng', 'Distance.mi.', 'Start_Lat', 'Pressure(in)',
'Humidity...', 'Wind_Chill.F.', 'Temperature_C',
'Weather_Condition', 'Airport_Code', 'Timezone')
# ************************************************* ----
# 4.0 Data Preparation ----
# *************************************************
transformed_data <- raw_data %>%
select('Start_Lng', 'Distance.mi.', 'Start_Lat', 'Pressure.in.',
'Humidity...', 'Wind_Chill.F.', 'Temperature_C',
'Weather_Condition', 'Airport_Code', 'Timezone')
# ************************************************* ----
# 5.0 Correlation Funnels ----
# *************************************************
#create recipe for the discretize object
discretize_obj <- recipe(~ ., data = transformed_data) %>%
step_zv(all_predictors()) %>%
step_discretize(all_numeric(), options = list(min_unique = 1)) %>%
step_dummy(all_nominal(), one_hot = TRUE) %>%
prep()
#bake
dist_tbl <- bake(discretize_obj, new_data = transformed_data)
View(dist_tbl)
# ************************************************* ----
# 4.0 Data Preparation ----
# *************************************************
transformed_data <- raw_data %>%
select('Severity', 'Start_Lng', 'Distance.mi.', 'Start_Lat', 'Pressure.in.',
'Humidity...', 'Wind_Chill.F.', 'Temperature_C',
'Weather_Condition', 'Airport_Code', 'Timezone')
# ************************************************* ----
# 5.0 Correlation Funnels ----
# *************************************************
#create recipe for the discretize object
discretize_obj <- recipe(~ ., data = transformed_data) %>%
step_zv(all_predictors()) %>%
step_discretize(all_numeric(), options = list(min_unique = 1)) %>%
step_dummy(all_nominal(), one_hot = TRUE) %>%
prep()
#bake
dist_tbl <- bake(discretize_obj, new_data = transformed_data)
# ************************************************* ----
# 5.0 When Distance is Small ----
# *************************************************
# Data manipulation.
correlation_bin4_tbl <- dist_tbl %>%
select(-c (date)) %>%
get_cor(Distance.mi._bin4, fct_reorder = T, fct_rev = T) %>%
filter(abs(Distance.mi._bin4) >= 0.02) %>%
mutate(
relationship = case_when(
Distance.mi._bin4 > 0 ~ "Supports",
TRUE ~ "Contradicts"
)
) %>%
mutate(feature_text = as.character(feature)) %>%
separate(feature_text, into = "feature_base", sep = "_", extra = "drop") %>%
mutate(feature_base = as_factor(feature_base) %>% fct_rev())
# ************************************************* ----
# 5.0 When Distance is Small ----
# *************************************************
# Data manipulation.
correlation_bin4_tbl <- dist_tbl %>%
get_cor(Distance.mi._bin4, fct_reorder = T, fct_rev = T) %>%
filter(abs(Distance.mi._bin4) >= 0.02) %>%
mutate(
relationship = case_when(
Distance.mi._bin4 > 0 ~ "Supports",
TRUE ~ "Contradicts"
)
) %>%
mutate(feature_text = as.character(feature)) %>%
separate(feature_text, into = "feature_base", sep = "_", extra = "drop") %>%
mutate(feature_base = as_factor(feature_base) %>% fct_rev())
# Visualization of discretized corr.
correlation_bin4_plot <- correlation_bin4_tbl %>%
ggplot(aes(Distance.mi._bin4, feature_base, color = fct_rev(relationship))) +
geom_point() +
geom_label(aes(label = feature), vjust = -0.5) +
expand_limits(x = c(-0.4, 0.4)) +
theme_tq() +
scale_color_tq() +
labs(
title = paste("Correlation Analysis: If Distance is LOW"),
subtitle = "How to read? Top correlated features are in the upper right, they then decrease in order downward (funnel)"
)
correlation_bin4_plot
